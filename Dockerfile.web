# Camada web: builda o frontend e o serve com o Caddy, que também injeta a
# API key nas chamadas para a API.
#
# O build do frontend acontece AQUI, e não na máquina de quem faz o deploy.
# Antes, o compose montava ./frontend/dist do host — mas `dist/` é ignorado
# pelo git, então um deploy que clona o repositório subiria sem interface.

# --- Build do frontend ------------------------------------------------------
FROM node:22-alpine AS frontend

WORKDIR /app

# Copiar só os manifestos primeiro aproveita o cache de camada: só refaz o
# npm ci quando as dependências mudam, não a cada alteração de código.
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

# --- Runtime ----------------------------------------------------------------
FROM caddy:2-alpine

COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=frontend /app/dist /srv/frontend

EXPOSE 8037

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://127.0.0.1:8037/health-web || exit 1
