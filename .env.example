# Copie para .env e ajuste. NUNCA versione o .env preenchido.

# Chaves de API válidas, separadas por vírgula.
# OBRIGATÓRIO: gere a sua. A API se recusa a iniciar com valor de exemplo ou
# com chave de menos de 24 caracteres.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# --- Interface ------------------------------------------------------------
# Diretório com o build do frontend. Vazio = a aplicação serve só a API
# (é o caso em desenvolvimento, onde o Vite serve a interface na 5173).
FRONTEND_DIR=
# Com true, quem abrir o site usa a API sem informar chave. É o mesmo
# alcance que um proxy injetando uma chave única para todo visitante teria.
# Deixe false se o serviço não deve ficar aberto a quem souber o endereço.
UI_PUBLIC=false

# Origens permitidas no CORS (deixe vazio quando o frontend for servido
# pelo mesmo domínio, que é o cenário recomendado).
CORS_ORIGINS=

# Armazenamento
STORAGE_DIR=storage
MAX_UPLOAD_BYTES=209715200
# Quota do serviço inteiro (20 GB).
MAX_STORAGE_BYTES=21474836480
# Quota por chave de API (10 GB). Impede que uma chave sozinha encha o
# disco e trave todas as outras. Vale a pena manter abaixo da metade da
# quota global quando houver mais de um cliente.
MAX_STORAGE_BYTES_PER_KEY=10737418240
MAX_ZIP_BYTES=4294967296
# Horas até um job terminado ser apagado. Um job de 50 variações de um vídeo
# de 100 MB passa de 5 GB, e o fluxo real é criar e baixar em minutos — a
# hora de folga cobre um download que falhou, sem obrigar a refazer o job.
# A limpeza roda a cada CLEANUP_INTERVAL_SECONDS, então na prática um job
# vive entre 1h e 1h15.
RETENTION_HOURS=1
CLEANUP_INTERVAL_SECONDS=900

# Apaga os arquivos do job assim que o download em lote (ZIP) termina.
# Trade-off: libera vários GB na hora, mas o job não pode ser rebaixado —
# um download interrompido perde os arquivos e obriga a refazer o job.
# Ligue só quando o disco for o recurso escasso.
DELETE_AFTER_BATCH_DOWNLOAD=false

# Reconciliação disco x banco (no start e a cada ciclo de limpeza):
# diretório sem registro é apagado, registro sem diretório vira expirado.
RECONCILE_ENABLED=true
# Folga antes de apagar um upload que nenhum job reivindica. Evita corrida
# com um upload recém-gravado que ainda não virou registro no banco.
UNREFERENCED_UPLOAD_GRACE_SECONDS=3600

# Observabilidade
# Percentual da quota global que dispara aviso no log.
STORAGE_WARN_PERCENT=80
# Uma linha JSON por evento. Desligue só para depurar no terminal.
LOG_JSON=true
LOG_LEVEL=INFO

# Processamento
MAX_VARIATIONS_PER_JOB=50
# Teto global de processos FFmpeg simultâneos, somando todos os jobs.
MAX_CONCURRENT_FFMPEG=4
FFMPEG_TIMEOUT_SECONDS=300
# Preset do libx264. `ultrafast` encoda pouco mais rápido e gera arquivo 2 a
# 3 vezes maior — o que volta como custo em disco, ZIP e download.
# Ordem do mais rápido ao mais lento: ultrafast, superfast, veryfast, faster,
# fast, medium.
FFMPEG_PRESET=veryfast
# Threads por processo de FFmpeg. 0 = o FFmpeg decide, o que com vários
# processos ao mesmo tempo cria mais threads que núcleos e desperdiça tempo
# em troca de contexto. Comece por (núcleos ÷ MAX_CONCURRENT_FFMPEG).
FFMPEG_THREADS=0
# Limites do vídeo de entrada (8192x8192 e 1 hora por padrão).
MAX_INPUT_PIXELS=67108864
MAX_INPUT_DURATION_SECONDS=3600

# Limites por chave
RATE_LIMIT_JOBS_PER_HOUR=20
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# --- Deploy com Docker Compose -------------------------------------------
# Usados só pelo docker-compose.yml; a aplicação não lê API_CPUS/API_MEMORY.
#
# Tetos de recurso do container (FFmpeg é o consumidor real).
API_CPUS=4.0
API_MEMORY=4g
#
# A aplicação escuta na porta 8037 e serve interface e API na mesma origem.
# Não publica porta no host: quem termina TLS e roteia o domínio é o proxy
# da plataforma.
#   - No Coolify: atribua o domínio pelo painel. O SERVICE_FQDN_APP_8037 é
#     preenchido pela própria plataforma; não precisa declarar nada aqui.
#   - Fora do Coolify: `make docker-up` publica a 8037 localmente.
